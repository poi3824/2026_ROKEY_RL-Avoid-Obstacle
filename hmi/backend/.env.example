# hmi/backend .env - 로컬 개발용. 실제 .env는 git에 커밋하지 않는다.
HMI_BACKEND_HOST=0.0.0.0
HMI_BACKEND_PORT=5100
HMI_BACKEND_DEBUG=1

# hmi_ros_bridge(/ros 네임스페이스)가 접속할 때 제시해야 하는 공유 시크릿.
# hmi_ros_bridge 쪽 .env의 HMI_BRIDGE_TOKEN과 반드시 같은 값이어야 한다 - 값이
# 어긋나면 연결이 조용히 거부되니(ConnectionRefusedError), 로그에서 확인할 것.
HMI_BRIDGE_TOKEN=changeme-shared-secret

# command_id 중복 방지 / command_ack,command_result 대기 pending 엔트리 TTL(초)
HMI_COMMAND_DEDUP_TTL_SEC=60
HMI_PENDING_CONTROL_TTL_SEC=30
