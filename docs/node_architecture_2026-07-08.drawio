<mxfile host="app.diagrams.net" modified="2026-07-08T00:00:00.000Z" agent="claude" version="24.0.0">
  <diagram name="노드 구조" id="node-architecture-page">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2700" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="robot_ws 노드 구조 (2026-07-08 기준)" style="text;html=1;fontSize=40;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="700" y="10" width="1300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="&lt;b&gt;범례&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#000000&quot;&gt;――――&lt;/span&gt; topic&lt;br&gt;&lt;span style=&quot;color:#0000CC&quot;&gt;- - - -&lt;/span&gt; service&lt;br&gt;&lt;span style=&quot;color:#009900&quot;&gt;━━━━&lt;/span&gt; action&lt;br&gt;&lt;span style=&quot;color:#FF0000&quot;&gt;━━━━&lt;/span&gt; 하드정지(직접)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=15;fillColor=#f5f5f5;strokeColor=#666666;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="2320" y="10" width="330" height="140" as="geometry" />
        </mxCell>

        <!-- ===== 외부 하드웨어/드라이버 (이 워크스페이스 밖) ===== -->
        <mxCell id="cam" value="&lt;b&gt;RealSense Camera Node&lt;/b&gt;&lt;br&gt;(외부 실행: realsense2_camera)&lt;br&gt;&lt;br&gt;발행 토픽:&lt;br&gt;/camera/camera/color/image_raw&lt;br&gt;/camera/camera/aligned_depth_to_color/image_raw&lt;br&gt;/camera/camera/color/camera_info" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=16;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="480" height="200" as="geometry" />
        </mxCell>

        <mxCell id="doosan" value="&lt;b&gt;Doosan 로봇 드라이버&lt;/b&gt;&lt;br&gt;(외부 실행: dsr_bringup2)&lt;br&gt;&lt;br&gt;제공 서비스:&lt;br&gt;DSR_ROBOT2 (movel/amovel/movej/&lt;br&gt;check_motion/get_current_posx 등)&lt;br&gt;/dsr01/motion/move_stop" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=16;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1560" y="120" width="480" height="200" as="geometry" />
        </mxCell>

        <mxCell id="gripper" value="&lt;b&gt;OnRobot RG2 그리퍼&lt;/b&gt;&lt;br&gt;192.168.1.1:502 (Modbus TCP, ROS 아님)&lt;br&gt;&lt;br&gt;레지스터 0: 힘/폭 명령(grip/stop)&lt;br&gt;레지스터 267: 실제 너비(1/10mm)&lt;br&gt;레지스터 268: busy / grip_detected" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=16;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="2140" y="420" width="480" height="200" as="geometry" />
        </mxCell>

        <!-- ===== 이 워크스페이스 노드들 ===== -->
        <mxCell id="objdet" value="&lt;b&gt;object_detection_node&lt;/b&gt;&lt;br&gt;(object_detection 패키지)&lt;br&gt;&lt;br&gt;Executor: MultiThreadedExecutor(2)&lt;br&gt;콜백그룹 분리: hand_cbg / depth_cbg&lt;br&gt;(2026-07-08 — 서로 지연 안 주게 분리)&lt;br&gt;&lt;br&gt;제공 서비스: /get_3d_position&lt;br&gt;(SrvDepthPosition, target 라벨 YOLO 탐지)&lt;br&gt;발행 토픽: /hand_detected&lt;br&gt;(0.3초 주기, 최근 5회 판정 다수결)&lt;br&gt;&lt;br&gt;내부: ImgNode(RealSense 구독),&lt;br&gt;YoloModel(yolov8s_seg_250.pt)&lt;br&gt;파일: detection.py / yolo.py / realsense.py" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=16;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="560" height="440" as="geometry" />
        </mxCell>

        <mxCell id="safety" value="&lt;b&gt;safety_monitor_node&lt;/b&gt;&lt;br&gt;(safety_monitor 패키지)&lt;br&gt;&lt;br&gt;구독: /hand_detected, /voice/estop&lt;br&gt;제공 서비스: /safety/estop, /safety/reset&lt;br&gt;호출 서비스: /dsr01/motion/move_stop&lt;br&gt;(브레인 상태와 무관하게 즉시 하드정지)&lt;br&gt;&lt;br&gt;발행 토픽: /safety/state&lt;br&gt;(RUN / PAUSE / ESTOP, 0.5초 하트비트)&lt;br&gt;&lt;br&gt;파일: safety_monitor_node.py" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=16;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="780" y="460" width="520" height="380" as="geometry" />
        </mxCell>

        <mxCell id="motion" value="&lt;b&gt;motion_node&lt;/b&gt;&lt;br&gt;(my_robot_pkg 패키지)&lt;br&gt;&lt;br&gt;Executor: MultiThreadedExecutor(4)&lt;br&gt;ReentrantCallbackGroup + goal_callback&lt;br&gt;(2026-07-08 — 동시 goal 실행 차단)&lt;br&gt;&lt;br&gt;제공 액션: motion/move_to, /pick, /place&lt;br&gt;호출 서비스: /get_3d_position&lt;br&gt;구독: /safety/state&lt;br&gt;&lt;br&gt;내부: dsr_node(DR_init 연동),&lt;br&gt;MotionExecutor(move_linear/pick/place),&lt;br&gt;RG2Gripper(Modbus 직접 소켓)&lt;br&gt;파일: motion_node.py / motion_executor.py / gripper.py" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=16;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="1560" y="460" width="560" height="440" as="geometry" />
        </mxCell>

        <mxCell id="keyword" value="&lt;b&gt;get_keyword_node&lt;/b&gt;&lt;br&gt;(voice_interface 패키지)&lt;br&gt;&lt;br&gt;백그라운드 스레드 상시 실행:&lt;br&gt;웨이크워드(&quot;헬로우 로키&quot;) 대기 → STT(Whisper)&lt;br&gt;→ LLM(GPT-4o) 명령 파싱&lt;br&gt;&lt;br&gt;제공 서비스: /get_keyword (Trigger)&lt;br&gt;발행 토픽: /voice/estop&lt;br&gt;(STOP 키워드 감지 시 LLM 안 거치고 즉시)&lt;br&gt;&lt;br&gt;세션: MAX_SESSION_SEC 동안 재웨이크 없이&lt;br&gt;연속 명령 (2026-07-08 추가)&lt;br&gt;&lt;br&gt;파일: robot_get_keyword_node.py / stt.py /&lt;br&gt;wakeup_word.py / MicController.py" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=16;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="60" y="980" width="560" height="400" as="geometry" />
        </mxCell>

        <mxCell id="brain" value="&lt;b&gt;brain_node&lt;/b&gt;&lt;br&gt;(my_robot_pkg 패키지, 오케스트레이터)&lt;br&gt;&lt;br&gt;Executor: SingleThreadedExecutor&lt;br&gt;(백그라운드 스레드) + 메인 루프(run_once)&lt;br&gt;&lt;br&gt;호출 서비스: /get_keyword, /safety/reset&lt;br&gt;액션 클라이언트: motion/move_to, /pick, /place&lt;br&gt;구독: /safety/state&lt;br&gt;&lt;br&gt;&quot;STOP&quot;/&quot;RESUME&quot; 명령 처리&lt;br&gt;POSITION_COORDS 관리(home/scan/target1~3)&lt;br&gt;&lt;br&gt;파일: brain_node.py" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=16;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="780" y="980" width="520" height="380" as="geometry" />
        </mxCell>

        <!-- ===== 연결선 ===== -->
        <mxCell id="e1" value="color/depth/camera_info (topic)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=15;strokeWidth=2;" edge="1" parent="1" source="cam" target="objdet">
          <mxGeometry relative="1" as="geometry" />
