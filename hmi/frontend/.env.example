# hmi/frontend .env - Vite는 VITE_ 접두사가 붙은 변수만 클라이언트 번들에 노출한다.
# cp .env.example .env 후 값 조정.
VITE_API_BASE=http://localhost:5100
VITE_SOCKET_URL=http://localhost:5100

# Phase 4까지는 hmi_vision_bridge의 MJPEG 스트림을 이 URL로 직접 하드코딩 없이 참조한다.
# 최종적으로는 Flask가 /stream/vision 으로 같은 origin proxy를 제공해 이 값이
# VITE_API_BASE 하나로 합쳐지는 게 목표(README 참고).
VITE_VISION_STREAM_URL=http://localhost:8766
