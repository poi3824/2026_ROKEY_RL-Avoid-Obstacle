# hmi/frontend .env - Vite는 VITE_ 접두사가 붙은 변수만 클라이언트 번들에 노출한다.
# cp .env.example .env 후 값 조정.
VITE_API_BASE=http://localhost:5100
VITE_SOCKET_URL=http://localhost:5100

# hmi_ros_bridge의 hmi_vision_stream(MJPEG) 주소 - 하드코딩 금지, 이 env로만 참조.
# 기존 hmi_interface의 vision_bridge.py(8766, 자체 YOLO 로드)는 그대로 병행
# 운영 중이라 포트를 겹치지 않게 8767을 쓴다. 최종적으로는 Flask가 /stream/vision
# 으로 같은 origin proxy를 제공해 이 값이 VITE_API_BASE 하나로 합쳐지는 게 목표(README 참고).
VITE_VISION_STREAM_URL=http://localhost:8767
