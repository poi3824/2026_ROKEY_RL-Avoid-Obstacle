        <mxCell id="e5" value="/get_keyword (service)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=15;dashed=1;strokeColor=#0000CC;strokeWidth=2;" edge="1" parent="1" source="keyword" target="brain">
          <mxGeometry relative="1" as="geometry" />
