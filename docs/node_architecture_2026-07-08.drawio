        <mxCell id="e6" value="/safety/state (topic)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=15;strokeWidth=2;" edge="1" parent="1" source="safety" target="brain">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e7" value="/safety/state (topic)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=15;strokeWidth=2;" edge="1" parent="1" source="safety" target="motion">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e8" value="/safety/reset (service)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=15;dashed=1;strokeColor=#0000CC;strokeWidth=2;" edge="1" parent="1" source="brain" target="safety">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e9" value="/dsr01/motion/move_stop&#10;(직접 하드정지)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=15;strokeColor=#FF0000;strokeWidth=3;" edge="1" parent="1" source="safety" target="doosan">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e10" value="motion/move_to, /pick, /place (action)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=15;strokeColor=#009900;strokeWidth=3;" edge="1" parent="1" source="brain" target="motion">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e11" value="DSR_ROBOT2 (amovel/movej/&#10;check_motion/get_current_posx)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=15;dashed=1;strokeColor=#0000CC;strokeWidth=2;" edge="1" parent="1" source="motion" target="doosan">
          <mxGeometry relative="1" as="geometry" />
